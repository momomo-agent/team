{
  "version": "3.0",
  "name": "dev-team",
  "description": "AI 开发团队 - 有向图 workflow",
  
  "workflow": {
    "entry": "startup",
    "nodes": {
      "startup": "nodes/startup.json",
      "work_loop": "nodes/work-loop.js",
      "quality_gate": "nodes/quality-gate.json",
      "standby": "nodes/standby.json"
    }
  },
  
  "agents": {
    "architect": {
      "prompt": "prompts/architect.md",
      "model": "claude-sonnet-4"
    },
    "vision_monitor": {
      "prompt": "prompts/vision_monitor.md",
      "model": "claude-sonnet-4"
    },
    "prd_monitor": {
      "prompt": "prompts/prd_monitor.md",
      "model": "claude-sonnet-4"
    },
    "dbb_monitor": {
      "prompt": "prompts/dbb_monitor.md",
      "model": "claude-sonnet-4"
    },
    "arch_monitor": {
      "prompt": "prompts/arch_monitor.md",
      "model": "claude-sonnet-4"
    },
    "pm": {
      "prompt": "prompts/pm.md",
      "model": "claude-sonnet-4"
    },
    "tech_lead": {
      "prompt": "prompts/tech_lead.md",
      "model": "claude-sonnet-4"
    },
    "developer": {
      "prompt": "prompts/developer.md",
      "model": "claude-sonnet-4",
      "scalable": true
    },
    "tester": {
      "prompt": "prompts/tester.md",
      "model": "claude-sonnet-4",
      "scalable": true
    }
  },
  
  "docs": {
    "root": ".team/docs",
    "items": [
      { "path": "VISION.md", "title": "愿景" },
      { "path": "PRD.md", "title": "产品需求" },
      { "path": "EXPECTED_DBB.md", "title": "预期验收" },
      { "path": "ARCHITECTURE.md", "title": "技术架构" },
      { "path": ".team/gaps", "title": "Gaps" },
      { "path": ".team/milestones", "title": "里程碑" },
      { "path": ".team/tasks", "title": "任务" }
    ]
  },
  
  "monitor": {
    "root": ".team/monitor",
    "agents": ["vision_monitor", "prd_monitor", "dbb_monitor", "arch_monitor"]
  },
  
  "git": {
    "commitPerTask": true,
    "tagPerMilestone": true
  },
  
  "notify": {
    "webhooks": [],
    "macos": true
  }
}
