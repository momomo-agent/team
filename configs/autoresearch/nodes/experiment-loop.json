{
  "type": "loop",
  "description": "实验循环 — stuck检测→回顾→假设→修改→评测",
  "maxIterations": 30,
  "steps": [
    {
      "id": "stuck-check",
      "execute": { "type": "function", "fn": "checkStuckExperiment" }
    },
    {
      "id": "review",
      "when": "doneCount > 0 && (doneCount % 3 === 0 || consecutiveReverts >= 3)",
      "execute": { "type": "agent", "agent": "reviewer" }
    },
    {
      "id": "hypothesize",
      "execute": { "type": "agent", "agent": "scientist" }
    },
    {
      "id": "experiment",
      "when": "todoCount > 0",
      "execute": { "type": "agent", "agent": "experimenter" }
    },
    {
      "id": "evaluate",
      "when": "reviewCount > 0 || testingCount > 0 || inProgressCount > 0",
      "execute": { "type": "agent", "agent": "evaluator" }
    }
  ],
  "exit": {
    "condition": "goalMet > 0 || (doneCount > 20)",
    "next": "analyze"
  }
}
