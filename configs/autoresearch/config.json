{
  "version": "1.0",
  "_workflow": "autoresearch",
  "groups": { "label": "experiments" },
  "dashboard": {
    "left": [
      {
        "id": "vision",
        "title": "Vision",
        "components": [
          { "component": "MarkdownView", "source": ".team/docs/VISION.md" }
        ]
      },
      {
        "id": "review",
        "title": "Review",
        "components": [
          { "component": "MarkdownView", "source": ".team/review.md" }
        ]
      },
      {
        "id": "metrics",
        "title": "Metrics",
        "badge": { "source": ".team/baseline.json", "field": "seedRecall", "suffix": "%" },
        "components": [
          { "component": "JsonlChart", "source": "experiments.log" },
          { "component": "JsonView", "source": ".team/stuck-signal.json", "label": "Stuck Signal" }
        ]
      },
      {
        "id": "conclusion",
        "title": "Conclusion",
        "components": [
          { "component": "MarkdownView", "source": ".team/conclusion.md" }
        ]
      }
    ],
    "right": [
      {
        "title": "Pipeline",
        "components": [{ "component": "PipelineView" }]
      },
      {
        "title": "Kanban",
        "components": [{ "component": "KanbanView" }]
      },
      {
        "title": "Experiments",
        "components": [{ "component": "MilestonesView" }]
      },
      {
        "title": "Logs",
        "components": [{ "component": "LogsView" }]
      }
    ]
  },
  "workflow": {
    "entry": "setup",
    "maxConcurrency": 2,
    "context": {
      "todoCount": "tasks.byStatus('todo').length",
      "doneCount": "tasks.byStatus('done').length",
      "inProgressCount": "tasks.byStatus('inProgress').length",
      "reviewCount": "tasks.byStatus('review').length",
      "testingCount": "tasks.byStatus('testing').length",
      "blockedCount": "tasks.byStatus('blocked').length",
      "hasEval": "files.exists('eval.js') || files.exists('eval.sh') || files.exists('eval.py') ? 1 : 0",
      "hasBaseline": "files.exists('.team/baseline.json') ? 1 : 0",
      "goalMet": "0",
      "consecutiveReverts": "0"
    },
    "nodes": {
      "setup": "nodes/setup.json",
      "experiment_loop": "nodes/experiment-loop.json",
      "analyze": "nodes/analyze.json",
      "complete": "nodes/complete.json"
    }
  },
  "agents": {
    "scientist": {
      "prompt": "prompts/research/scientist.md",
      "model": "claude-sonnet-4",
      "description": "分析现状，提出改进假设",
      "backend": "claude-code"
    },
    "experimenter": {
      "prompt": "prompts/research/experimenter.md",
      "model": "claude-sonnet-4",
      "description": "执行实验修改（只改一个变量）",
      "backend": "claude-code",
      "gitCommit": true,
      "gitPrefix": "exp"
    },
    "evaluator": {
      "prompt": "prompts/research/evaluator.md",
      "model": "claude-sonnet-4",
      "description": "跑 eval，对比基线，决定 keep/revert",
      "backend": "claude-code",
      "gitCommit": true
    },
    "setup_agent": {
      "prompt": "prompts/research/setup.md",
      "model": "claude-sonnet-4",
      "description": "建立基线和评测脚本",
      "backend": "claude-code"
    },
    "reviewer": {
      "prompt": "prompts/research/reviewer.md",
      "model": "claude-sonnet-4",
      "description": "回顾实验历史，发现模式，调整方向",
      "backend": "claude-code"
    }
  },
  "git": { "commitPerTask": false },
  "notify": {}
}
