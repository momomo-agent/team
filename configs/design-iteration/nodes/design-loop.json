{
  "type": "sequence",
  "description": "设计迭代循环：设计 → 开发 → 审核",
  "steps": [
    {
      "id": "design",
      "execute": { "type": "agent", "agent": "designer" },
      "post": {
        "write": ".team/iterations/design-{{iteration}}.md"
      }
    },
    {
      "id": "develop",
      "execute": { "type": "agent", "agent": "developer" },
      "post": {
        "git": "commit -am 'design iteration {{iteration}}'"
      }
    },
    {
      "id": "review",
      "execute": { "type": "agent", "agent": "reviewer" },
      "post": {
        "write": ".team/iterations/review-{{iteration}}.json"
      }
    },
    {
      "id": "increment",
      "execute": {
        "type": "shell",
        "command": "expr $(cat .team/iteration-count.txt) + 1 > .team/iteration-count.txt"
      }
    },
    {
      "id": "check-completion",
      "execute": {
        "type": "shell",
        "command": "ITER=$(cat .team/iteration-count.txt); GAP=$(node -pe \"JSON.parse(require('fs').readFileSync('.team/iterations/review-${ITER}.json','utf8')).gapScore||100\"); test \"$GAP\" -lt 20 -o \"$ITER\" -ge 20"
      },
      "next": {
        "success": "complete",
        "failure": "design-loop"
      }
    }
  ]
}
