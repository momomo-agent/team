{
  "name": "design-iteration",
  "description": "UI/UX 设计迭代流程：设计 → 开发 → 审核 → 循环",
  "version": "1.0.0",
  "workflow": {
    "entry": "startup",
    "context": {
      "maxIterations": 20,
      "gapThreshold": 20
    }
  },
  "agents": {
    "designer": {
      "role": "UI/UX Designer",
      "prompt": "configs/design-iteration/prompts/designer.md",
      "capabilities": ["read", "write_design"]
    },
    "developer": {
      "role": "Frontend Developer",
      "prompt": "configs/design-iteration/prompts/developer.md",
      "capabilities": ["read", "write_code", "git"]
    },
    "reviewer": {
      "role": "Design Reviewer",
      "prompt": "configs/design-iteration/prompts/reviewer.md",
      "capabilities": ["read", "screenshot", "evaluate"]
    }
  }
}
