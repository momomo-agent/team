{
  "version": "3.0",
  "name": "dev-team",
  "description": "AI 开发团队 - 有向图 workflow",
  
  "workflow": {
    "entry": "startup",
    "nodes": {
      "startup": "nodes/startup.json",
      "work_loop": "nodes/work-loop.js",
      "quality_gate": "nodes/quality-gate.json",
      "standby": "nodes/standby.json"
    }
  },
  
  "dashboard": {
    "left": [
      {
        "id": "vision",
        "title": "愿景",
        "type": "doc",
        "path": "VISION.md",
        "showInUI": true
      },
      {
        "id": "prd",
        "title": "产品需求",
        "type": "doc",
        "path": "PRD.md",
        "showInUI": true
      },
      {
        "id": "dbb",
        "title": "预期验收",
        "type": "doc",
        "path": "EXPECTED_DBB.md",
        "showInUI": true
      },
      {
        "id": "arch",
        "title": "技术架构",
        "type": "doc",
        "path": "ARCHITECTURE.md",
        "showInUI": true
      }
    ],
    "right": [
      {
        "id": "pipeline",
        "title": "Pipeline",
        "type": "view",
        "component": "PipelineView",
        "dataSource": {
          "type": "file",
          "path": ".team/milestones/milestones.json"
        }
      },
      {
        "id": "kanban",
        "title": "Kanban",
        "type": "view",
        "component": "KanbanView",
        "dataSource": {
          "type": "file",
          "path": ".team/kanban.json"
        }
      },
      {
        "id": "milestones",
        "title": "Milestones",
        "type": "view",
        "component": "MilestonesView",
        "dataSource": {
          "type": "file",
          "path": ".team/milestones/milestones.json"
        }
      }
    ]
  },
  
  "agents": {
    "architect": { "prompt": "prompts/architect.md", "model": "claude-sonnet-4" },
    "vision_monitor": { "prompt": "prompts/vision_monitor.md", "model": "claude-sonnet-4" },
    "prd_monitor": { "prompt": "prompts/prd_monitor.md", "model": "claude-sonnet-4" },
    "dbb_monitor": { "prompt": "prompts/dbb_monitor.md", "model": "claude-sonnet-4" },
    "arch_monitor": { "prompt": "prompts/arch_monitor.md", "model": "claude-sonnet-4" },
    "pm": { "prompt": "prompts/pm.md", "model": "claude-sonnet-4" },
    "tech_lead": { "prompt": "prompts/tech_lead.md", "model": "claude-sonnet-4" },
    "developer": { "prompt": "prompts/developer.md", "model": "claude-sonnet-4", "scalable": true },
    "tester": { "prompt": "prompts/tester.md", "model": "claude-sonnet-4", "scalable": true }
  },
  
  "docs": {
    "root": ".team/docs"
  },
  
  "monitor": {
    "root": ".team/monitor",
    "agents": ["vision_monitor", "prd_monitor", "dbb_monitor", "arch_monitor"]
  },
  
  "git": {
    "commitPerTask": true,
    "tagPerMilestone": true
  },
  
  "notify": {
    "webhooks": [],
    "macos": true
  }
}
