{
  "type": "loop",
  "description": "PM 调度中心 — PM 评估后派发 sub-teams，全部完成后回 PM",
  "maxIterations": 50,
  "steps": [
    {
      "id": "goal-check",
      "execute": {
        "type": "shell",
        "command": "node /Users/kenefe/LOCAL/momo-agent/tools/team/scripts/goal-check.js"
      }
    },
    {
      "id": "pm-dispatch",
      "execute": {
        "type": "agent",
        "agent": "pm"
      }
    },
    {
      "id": "write-dbb",
      "when": "milestoneNeedsDBB > 0",
      "execute": {
        "type": "agent",
        "agent": "qa_lead"
      }
    },
    {
      "id": "parallel-execute",
      "parallel": true,
      "branches": [
        {
          "id": "architecture",
          "when": "archTaskCount > 0 || todoWithoutDesign > 0",
          "execute": {
            "type": "team",
            "config": "architect-team"
          }
        },
        {
          "id": "write-design",
          "when": "todoWithoutDesign > 0",
          "demand": "todoWithoutDesign",
          "execute": {
            "type": "agent",
            "agent": "tech_lead",
            "parallel": 3
          }
        },
        {
          "id": "implement",
          "when": "designedTasks > 0",
          "demand": "designedTasks",
          "execute": {
            "type": "team",
            "config": "developer-team"
          },
          "post": {
            "tasks_in": "inProgress",
            "success_status": "review",
            "on_no_evidence": "review"
          }
        },
        {
          "id": "test",
          "when": "reviewCount > 0 || testingCount > 0",
          "demand": "reviewCount + testingCount",
          "execute": {
            "type": "team",
            "config": "tester-team"
          },
          "post": {
            "tasks_in": "testing",
            "success_status": "done",
            "on_fail_signal": {
              "contains": "fail",
              "not_contains": "0 fail",
              "status": "blocked"
            },
            "on_no_evidence": "review",
            "on_empty_evidence": "review"
          }
        }
      ]
    },
    {
      "id": "triage-blocked",
      "description": "PM 处理 blocked 任务 — 分析错误日志，决定路由",
      "when": "blockedCount > 0",
      "execute": {
        "type": "agent",
        "agent": "pm"
      }
    }
  ],
  "exit": {
    "condition": "todoCount == 0 && designedTasks == 0 && reviewCount == 0 && inProgressCount == 0 && testingCount == 0 && blockedCount == 0",
    "next": {
      "if": "doneCount > 0",
      "then": "milestone_qg",
      "else": "standby"
    }
  }
}
