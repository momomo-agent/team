{
  "type": "sequence",
  "description": "里程碑 QG — 对照 DBB 验收",
  "steps": [
    {
      "id": "qg-test",
      "execute": { "type": "agent", "agent": "tester" },
      "post": {
        "tasks_in": "testing",
        "success_status": "done",
        "evidence": "test-result.md",
        "on_fail_signal": { "contains": "fail", "not_contains": "0 fail", "status": "blocked" },
        "on_no_evidence": "review",
        "on_empty_evidence": "review"
      }
    },
    {
      "id": "qg-decision",
      "execute": { "type": "agent", "agent": "pm" }
    },
    {
      "id": "cross-validate",
      "when": "milestoneComplete",
      "execute": { "type": "function", "fn": "crossValidateMonitors" }
    },
    {
      "id": "mark-complete",
      "when": "milestoneComplete",
      "execute": { "type": "function", "fn": "markMilestoneComplete" }
    },
    {
      "id": "auto-tag",
      "when": "milestoneComplete",
      "execute": { "type": "function", "fn": "autoGitCommit" }
    }
  ],
  "next": {
    "if": "milestoneComplete",
    "then": "monitor",
    "else": "work_loop"
  }
}
