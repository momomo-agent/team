{
  "type": "sequence",
  "description": "项目完成 — 最终验证 + 归档 + 报告",
  "steps": [
    {
      "id": "final-monitors",
      "parallel": true,
      "branches": [
        { "id": "final-vision", "execute": { "type": "agent", "agent": "vision_monitor" } },
        { "id": "final-prd", "execute": { "type": "agent", "agent": "prd_monitor" } },
        { "id": "final-dbb", "execute": { "type": "agent", "agent": "dbb_monitor" } },
        { "id": "final-arch", "execute": { "type": "agent", "agent": "arch_monitor" } }
      ]
    },
    {
      "id": "final-cross-validate",
      "execute": { "type": "function", "fn": "crossValidateMonitors" }
    },
    {
      "id": "generate-report",
      "execute": { "type": "function", "fn": "generateReport" }
    },
    {
      "id": "final-tag",
      "execute": { "type": "function", "fn": "autoGitCommit" }
    }
  ]
}
