{
  "layers": [
    { "id": "L0", "name": "Vision", "file": "VISION.md", "gapsFile": "vision.json" },
    { "id": "L1", "name": "PRD", "file": "PRD.md", "gapsFile": "prd.json" },
    { "id": "L1", "name": "DBB", "file": "EXPECTED_DBB.md", "gapsFile": "dbb.json" },
    { "id": "L2", "name": "Architecture", "file": "ARCHITECTURE.md", "gapsFile": "architecture.json" }
  ],
  "agents": {
    "architect": {
      "prompt": "prompts/architect.md",
      "frequency": "once",
      "write": ["ARCHITECTURE.md", ".team/change-requests/"],
      "read": ["VISION.md", "PRD.md", "EXPECTED_DBB.md"]
    },
    "vision_monitor": {
      "prompt": "prompts/vision_monitor.md",
      "frequency": "milestone",
      "write": [".team/gaps/vision.json", ".team/milestones/*/review/"],
      "read": ["VISION.md", "src/", "ARCHITECTURE.md"]
    },
    "prd_monitor": {
      "prompt": "prompts/prd_monitor.md",
      "frequency": "milestone",
      "write": [".team/gaps/prd.json", ".team/milestones/*/review/"],
      "read": ["PRD.md", "EXPECTED_DBB.md", "src/", "ARCHITECTURE.md"]
    },
    "dbb_monitor": {
      "prompt": "prompts/dbb_monitor.md",
      "frequency": "milestone",
      "write": [".team/gaps/dbb.json", ".team/gaps/milestones/", ".team/milestones/*/review/"],
      "read": ["EXPECTED_DBB.md", ".team/milestones/*/dbb.md", "src/"]
    },
    "arch_monitor": {
      "prompt": "prompts/arch_monitor.md",
      "frequency": "milestone",
      "write": [".team/gaps/architecture.json", ".team/milestones/*/review/"],
      "read": ["ARCHITECTURE.md", "src/"]
    },
    "pm": {
      "prompt": "prompts/pm.md",
      "frequency": "per-loop",
      "write": [".team/milestones/milestones.json", ".team/milestones/*/overview.md", ".team/kanban.json", ".team/tasks/*/task.json", ".team/change-requests/"],
      "read": ["ARCHITECTURE.md", ".team/gaps/", ".team/milestones/", ".team/tasks/"]
    },
    "tech_lead": {
      "prompt": "prompts/tech_lead.md",
      "frequency": "per-loop",
      "write": [".team/milestones/*/dbb.md", ".team/milestones/*/design.md", ".team/tasks/*/design.md", ".team/tasks/*/task.json", ".team/change-requests/"],
      "read": ["ARCHITECTURE.md", ".team/milestones/", ".team/tasks/", ".team/kanban.json"]
    },
    "developer": {
      "prompt": "prompts/developer.md",
      "frequency": "per-loop",
      "scalable": true,
      "write": ["src/", "lib/", "test/", ".team/tasks/*/progress.md", ".team/tasks/*/task.json", ".team/change-requests/"],
      "read": [".team/tasks/*/design.md", ".team/tasks/*/task.json", ".team/kanban.json", "ARCHITECTURE.md"]
    },
    "tester": {
      "prompt": "prompts/tester.md",
      "frequency": "per-loop",
      "scalable": true,
      "write": ["test/", ".team/tasks/*/test-result.md", ".team/tasks/*/task.json", ".team/gaps/test-coverage.json", ".team/change-requests/"],
      "read": [".team/milestones/*/dbb.md", ".team/tasks/*/design.md", ".team/kanban.json"]
    }
  },
  "workflow": {
    "startup": [
      { "agents": ["architect"], "parallel": false, "condition": "no-architecture" },
      { "agents": ["vision_monitor", "prd_monitor", "dbb_monitor", "arch_monitor"], "parallel": true },
      { "agents": ["pm"], "parallel": false }
    ],
    "loop": {
      "parallel": ["tech_lead", "developer", "tester"],
      "then": ["pm"]
    },
    "milestoneCheck": {
      "parallel": ["vision_monitor", "prd_monitor", "dbb_monitor", "arch_monitor"],
      "then": ["pm"]
    }
  },
  "git": {
    "commitPerTask": true,
    "tagPerMilestone": true
  },
  "notify": {
    "discord": { "channel": "" },
    "macos": true,
    "webhooks": []
  }
}